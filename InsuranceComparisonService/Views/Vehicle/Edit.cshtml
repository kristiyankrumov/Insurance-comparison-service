@model InsuranceComparisonService.Models.Vehicle
@{
    ViewData["Title"] = "Редактирай превозно средство";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0"><i class="bi bi-pencil"></i> Редактирай превозно средство</h4>
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        { <div>@e.ErrorMessage</div> }
                    </div>
                }
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label fw-bold">Марка</label>
                            <input asp-for="Make" class="form-control" required />
                        </div>
                        <div class="col">
                            <label class="form-label fw-bold">Модел</label>
                            <input asp-for="Model" class="form-control" required />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label fw-bold">Година</label>
                            <input asp-for="Year" type="number" class="form-control" min="1950" max="2026" required />
                        </div>
                        <div class="col">
                            <label class="form-label fw-bold">Рег. номер</label>
                            <input asp-for="PlateNumber" class="form-control" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Мощност (к.с.)</label>
                        <input asp-for="HorsePower" type="number" class="form-control" min="50" max="2000" />
                    </div>
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label fw-bold">Вид гориво</label>
                            <select asp-for="FuelType" class="form-select">
                                <option value="0">Бензин</option>
                                <option value="1">Дизел</option>
                                <option value="2">Електро</option>
                                <option value="3">Хибрид</option>
                            </select>
                        </div>
                        <div class="col">
                            <label class="form-label fw-bold">Категория</label>
                            <select asp-for="Category" class="form-select">
                                <option value="0">Лек автомобил</option>
                                <option value="1">Мотоциклет</option>
                                <option value="2">Камион</option>
                                <option value="3">Автобус</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-warning w-100">
                        <i class="bi bi-save"></i> Запази промените
                    </button>
                </form>
            </div>
        </div>
        <div class="mt-3">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Обратно
            </a>
        </div>
    </div>
</div>
