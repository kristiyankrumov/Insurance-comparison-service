@model IEnumerable<InsuranceComparisonService.Models.InsurancePolicy>
@{
    ViewData["Title"] = "Моите застраховки";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-file-earmark-check text-success"></i> Моите застраховки</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        Нямаш активни или минали застраховки.
        <a asp-controller="Home" asp-action="Index" class="alert-link">Разгледай оферти</a>
    </div>
}
else
{
    int active = Model.Count(p => p.Status == InsuranceComparisonService.Models.PolicyStatus.Active);
    int expired = Model.Count(p => p.Status == InsuranceComparisonService.Models.PolicyStatus.Expired);
    int cancelled = Model.Count(p => p.Status == InsuranceComparisonService.Models.PolicyStatus.Cancelled);
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-success">@active</div>
                <div class="text-muted">Активни</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-secondary">@expired</div>
                <div class="text-muted">Изтекли</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-danger">@cancelled</div>
                <div class="text-muted">Анулирани</div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Полица №</th>
                    <th>Оферта</th>
                    <th>Компания</th>
                    <th>МПС</th>
                    <th>Период</th>
                    <th>Цена</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><code>@p.PolicyNumber</code></td>
                        <td>@p.Offer?.Title</td>
                        <td>@p.Offer?.Company?.Name</td>
                        <td>
                            @if (p.Vehicle != null)
                            { <span class="badge bg-secondary">@p.Vehicle.PlateNumber</span> }
                            else
                            { <span class="text-muted">—</span> }
                        </td>
                        <td class="small">
                            @p.StartDate.ToString("dd.MM.yyyy") —
                            @p.EndDate.ToString("dd.MM.yyyy")
                        </td>
                        <td class="fw-bold">@p.FinalPrice лв.</td>
                        <td>
                            @{
                                string badgeClass, label;
                                if (p.Status == InsuranceComparisonService.Models.PolicyStatus.Active)
                                { badgeClass = "bg-success"; label = "Активна"; }
                                else if (p.Status == InsuranceComparisonService.Models.PolicyStatus.Expired)
                                { badgeClass = "bg-secondary"; label = "Изтекла"; }
                                else
                                { badgeClass = "bg-danger"; label = "Анулирана"; }
                            }
                            <span class="badge @badgeClass">@label</span>
                        </td>
                        <td>
                            @if (p.Status == InsuranceComparisonService.Models.PolicyStatus.Active)
                            {
                                <form asp-action="Cancel" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Сигурен ли си, че искаш да анулираш полицата?')">
                                        <i class="bi bi-x-circle"></i> Анулирай
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Обратно към профила
    </a>
</div>
